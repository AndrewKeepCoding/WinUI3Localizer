<Page
    x:Class="WinUI3Localizer.SampleApp.Pages.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:l="using:WinUI3Localizer"
    xmlns:local="using:WinUI3Localizer.SampleApp.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tv="using:WinUI.TableView"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">
    <Grid>
        <!--  Navigation menu  -->
        <NavigationView x:Name="NavigationViewControl"
            PaneDisplayMode="Top"
            SelectionChanged="NavigationView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem
                    l:Uids.Uid="MainWindow_NavigationView_ControlsPage"
                    Icon="ViewAll"
                    IsSelected="True"
                    Tag="ControlsPage" />
                <NavigationViewItem
                    l:Uids.Uid="MainWindow_NavigationView_ItemTemplatesPage"
                    Icon="AllApps"
                    Tag="ItemTemplatesPage" />
                <NavigationViewItem
                    l:Uids.Uid="MainWindow_NavigationView_StylesPage"
                    Icon="Library"
                    Tag="StylesPage" />
                <NavigationViewItem
                    l:Uids.Uid="MainWindow_NavigationView_LocalizationActionsPage"
                    Icon="PreviewLink"
                    Tag="LocalizationActionsPage" />
                <NavigationViewItem
                    l:Uids.Uid="MainWindow_NavigationView_MultipleResourcesPage"
                    Icon="Bullets"
                    Tag="MultipleResourcesPage" />
                <NavigationViewItem
                    l:Uids.Uid="MainWindow_NavigationView_NonStringValuesPage"
                    Icon="Flag"
                    Tag="NonStringValuesPage" />
                <NavigationViewItem
                    l:Uids.Uid="MainWindow_NavigationView_DynamicDictionariesPage"
                    Icon="PhoneBook"
                    Tag="DynamicDictionariesPage" />
            </NavigationView.MenuItems>

            <!--  Navigation content  -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="500" />
                </Grid.ColumnDefinitions>
                <Frame x:Name="ContentFrame"
                    Grid.Column="0"
                    Margin="20,10" />
                <Grid
                    Grid.Column="1"
                    Margin="20,10"
                    RowDefinitions="Auto,*">
                    <TextBlock
                        Grid.Row="0"
                        Style="{StaticResource SubtitleTextBlockStyle}"
                        Text="String resources" />
                    <tv:TableView x:Name="LanguageDictionaryTableViewControl"
                        Grid.Row="1"
                        AutoGenerateColumns="False"
                        IsReadOnly="True"
                        SelectionMode="Single"
                        SelectionUnit="Row"
                        ShowExportOptions="True">
                        <tv:TableView.Columns>
                            <tv:TableViewTextColumn
                                Width="300"
                                Binding="{Binding StringResourceItemName}"
                                Header="Name" />
                            <tv:TableViewTextColumn Binding="{Binding Value}" Header="Value" />
                        </tv:TableView.Columns>
                    </tv:TableView>
                </Grid>
            </Grid>
        </NavigationView>
        <SplitButton x:Name="LanguagesSplitButton"
            Margin="0,10,150,0"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            l:Uids.Uid="MainWindow_LanguagesSplitButton"
            Click="LanguagesSplitButton_Click">
            <SplitButton.Flyout>
                <Flyout>
                    <ListView x:Name="LanguagesGridView"
                        ItemsSource="{x:Bind AvailableLanguages}"
                        SelectionChanged="LanguagesGridView_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:LanguageItem">
                                <TextBlock
                                    HorizontalAlignment="Left"
                                    l:Uids.Uid="{x:Bind UidKey}"
                                    HorizontalTextAlignment="Left" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Flyout>
            </SplitButton.Flyout>
        </SplitButton>
    </Grid>
</Page>