<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinUI3Localizer.SampleApp.Pages.DynamicDictionariesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:l="using:WinUI3Localizer"
    xmlns:local="using:WinUI3Localizer.SampleApp.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:tv="using:WinUI.TableView"
    mc:Ignorable="d">

    <Grid RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Spacing="8">
            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Add dictionaries" />
            <TextBlock Text="Add dictionaries." />
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="LanguageTextBox"
                    Grid.Column="0"
                    Header="Language" />
                <NumberBox x:Name="PriorityNumberBox"
                    Grid.Column="1"
                    Header="Priority"
                    Value="1" />
                <TextBox x:Name="NameTextBox"
                    Grid.Column="2"
                    Header="Name" />
                <Button
                    Grid.Column="3"
                    VerticalAlignment="Bottom"
                    Click="AddDictionaryButton_Click"
                    Content="Add Dictionary" />
            </Grid>
        </StackPanel>
        <StackPanel Grid.Row="1" Spacing="8">
            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Add items to dictionaries" />
            <TextBlock Text="Add items to the selected language dictionary." />
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="UidTextBox"
                    Grid.Column="0"
                    Header="Uid" />
                <TextBox x:Name="DependencyPropertyNameTextBox"
                    Grid.Column="1"
                    Header="Dependency Property Name" />
                <TextBox x:Name="ValueTextBox"
                    Grid.Column="2"
                    Header="Value" />
                <Button
                    Grid.Column="3"
                    VerticalAlignment="Bottom"
                    Click="AddItemButton_Click"
                    Content="Add Item" />
            </Grid>
        </StackPanel>
        <StackPanel Grid.Row="2" Spacing="8">
            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Language dictionaries" />
            <tv:TableView x:Name="LanguageDictionaryTableView"
                AutoGenerateColumns="False"
                ReorderMode="Disabled"
                ScrollViewer.HorizontalScrollBarVisibility="Visible">
                <tv:TableView.Resources>
                    <Color x:Key="DataGridColumnHeaderBackgroundColor">Transparent</Color>
                </tv:TableView.Resources>
                <tv:TableView.Columns>
                    <tv:TableViewTextColumn Binding="{Binding Language}" Header="Language" />
                    <tv:TableViewTextColumn Binding="{Binding Priority}" Header="Priority" />
                    <tv:TableViewTextColumn Binding="{Binding Name}" Header="Name" />
                    <tv:TableViewTextColumn Binding="{Binding Count}" Header="Items" />
                </tv:TableView.Columns>
            </tv:TableView>
        </StackPanel>
    </Grid>
</Page>